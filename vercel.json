{
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "public": false,
  "env": {
    "DATABASE_URL": {
      "description": "MySQL/TiDB database connection string"
    },
    "JWT_SECRET": {
      "description": "JWT signing secret for session cookies"
    },
    "VITE_APP_ID": {
      "description": "Manus OAuth Application ID"
    },
    "OAUTH_SERVER_URL": {
      "description": "Manus OAuth server base URL"
    },
    "VITE_OAUTH_PORTAL_URL": {
      "description": "Manus OAuth login portal URL"
    },
    "OWNER_OPEN_ID": {
      "description": "Owner's Manus Open ID"
    },
    "OWNER_NAME": {
      "description": "Owner's name"
    },
    "BUILT_IN_FORGE_API_URL": {
      "description": "Manus built-in Forge API URL"
    },
    "BUILT_IN_FORGE_API_KEY": {
      "description": "Manus built-in Forge API Key (server-side)"
    },
    "VITE_FRONTEND_FORGE_API_KEY": {
      "description": "Manus Forge API Key for frontend"
    },
    "VITE_FRONTEND_FORGE_API_URL": {
      "description": "Manus Forge API URL for frontend"
    },
    "VITE_APP_TITLE": {
      "description": "Application title"
    },
    "VITE_APP_LOGO": {
      "description": "Application logo URL"
    }
  },
  "regions": ["sin1"],
  "functions": {
    "api/**": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
