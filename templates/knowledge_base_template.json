    "escalation": {
      "transfer_keywords": ["投訴", "問題", "不滿", "退款", "幫我", "人工"],
      "transfer_message": "感謝您的反饋，我將轉接給專人處理。請稍候...",
      "transfer_to_department": "customer_service",
      "max_wait_time_seconds": 300
