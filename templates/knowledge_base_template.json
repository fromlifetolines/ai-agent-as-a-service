  "business_rules": {
    "booking": {
      "min_advance_notice_hours": 2,
      "max_advance_booking_days": 30,
      "max_concurrent_bookings_per_customer": 1,
      "allow_same_day_booking": true,
      "require_customer_confirmation": true,
      "confirmation_message": "感謝您的預約，我們已為您保留時段。請於預約時間前 10 分鐘到達。",
      "cancellation_policy": "預約前 24 小時可免費取消",
      "reschedule_policy": "可隨時改期，需提前 24 小時通知"
    },
    "pricing": {
      "currency": "TWD",
      "accept_payment_methods": ["cash", "credit_card", "line_pay"],
      "first_time_discount_percent": 0,
      "package_discounts": [
