    "customer_data": {
      "collect_phone": true,
      "collect_email": true,
      "collect_name": true,
      "collect_notes": true,
      "gdpr_compliant": true
    }
  },

  "conversation_flows": {
    "greeting": {
      "trigger_keywords": ["你好", "嗨", "hi", "hello"],
      "response": "您好！歡迎來到 [業務名稱]。我是 AI 客服助手，可以幫您預約或回答問題。請問有什麼我可以幫助的嗎？"
    },
    "booking_intent": {
      "trigger_keywords": ["預約", "掛號", "訂位", "預訂"],
      "response": "好的，我幫您預約。請告訴我：\n1. 您想預約的服務是什麼？\n2. 您的偏好日期是？\n3. 您的偏好時間是？"
    },
    "query_intent": {
      "trigger_keywords": ["營業", "時間", "地點", "價格", "費用", "多少錢"],
      "response": "我來幫您查詢相關資訊..."
    },
    "complaint_intent": {
      "trigger_keywords": ["投訴", "問題", "不滿", "退款"],
      "response": "感謝您的反饋。我將轉接給專人處理您的問題。"
    },
    "closing": {
      "trigger_keywords": ["謝謝", "再見", "bye", "thanks"],
      "response": "感謝您的光臨！如有任何問題，歡迎隨時聯絡我們。祝您有美好的一天！"
    }
  },

  "ai_prompts": {
    "system_prompt": "你是一個專業的客服助手，代表 [業務名稱] 與客戶互動。你的職責是：\n1. 理解客戶的需求\n2. 提供準確的資訊\n3. 協助客戶預約\n4. 在必要時轉接人工客服\n\n重要指示：\n- 始終保持禮貌與專業\n- 如果不確定，請誠實說明並轉接人工\n- 遵守業務規則（營業時間、預約政策等）\n- 使用繁體中文回應",
    
    "intent_extraction_prompt": "分析以下客戶訊息，並提取以下資訊（以 JSON 格式返回）：\n- intent: 意圖類型 (booking|query|complaint|greeting|other)\n- service: 服務類型（如果有）\n- preferred_date: 偏好日期（如果有）\n- preferred_time: 偏好時間（如果有）\n- customer_name: 客戶名稱（如果有）\n- customer_phone: 客戶電話（如果有）\n- confidence: 信心度 (0-1)\n\n客戶訊息：{message}",
    
    "availability_check_prompt": "根據以下資訊，檢查可用的預約時段：\n- 服務: {service_name}\n- 服務時長: {duration} 分鐘\n- 偏好日期: {preferred_date}\n- 偏好時間: {preferred_time}\n- 營業時間: {operating_hours}\n- 已預約時段: {booked_slots}\n\n請返回 3-5 個可用時段的建議。",
    
    "confirmation_prompt": "生成一個預約確認訊息，包含以下資訊：\n- 客戶名稱: {customer_name}\n- 服務: {service_name}\n- 日期: {booking_date}\n- 時間: {booking_time}\n- 地點: {location}\n- 提醒事項: {reminders}\n\n訊息應該友善、清晰且包含所有重要資訊。"
  },

  "templates": {
    "booking_confirmation": "✅ 預約成功！\n服務：{service_name}\n日期：{booking_date}\n時間：{booking_time}-{booking_end_time}\n地點：{location}\n\n提醒：\n• 請於預約時間前 10 分鐘到達\n• 如需取消，請提前 24 小時通知\n• 聯絡電話：{phone}",
    
    "booking_reminder": "📢 預約提醒\n您在 {business_name} 的預約即將開始\n時間：{booking_time}\n服務：{service_name}\n地點：{location}\n\n如需改期或取消，請回覆『改期』或『取消』",
    
    "no_availability": "抱歉，{preferred_date} {preferred_time} 無可用時段。\n\n建議時段：\n• {alternative_time_1}\n• {alternative_time_2}\n• {alternative_time_3}\n\n是否接受其中一個時段？",
    
    "transfer_to_human": "感謝您的耐心。我現在將您轉接給專人處理。\n預計等待時間：2-5 分鐘\n\n客服人員將很快與您聯絡。"
  },

  "analytics": {
    "track_conversation_count": true,
    "track_booking_success_rate": true,
    "track_customer_satisfaction": true,
    "track_transfer_rate": true,
    "track_average_response_time": true
  },

